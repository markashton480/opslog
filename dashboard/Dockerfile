FROM node:22-alpine AS builder

WORKDIR /app

ARG VITE_OPSLOG_API_URL=/api/v1
ARG VITE_AUTH_MODE=oidc
# Security note: this token is baked into static JS assets at build time.
# It MUST be a read-only (reader role) token - never use a writer/admin token here.
ARG VITE_OPSLOG_TOKEN=
ARG VITE_OIDC_AUTHORITY=
ARG VITE_OIDC_CLIENT_ID=
ARG VITE_OIDC_REDIRECT_URI=
ARG VITE_OIDC_POST_LOGOUT_REDIRECT_URI=
ARG VITE_OIDC_SCOPE=
ARG VITE_OIDC_SILENT_REDIRECT_URI=
ENV VITE_OPSLOG_API_URL=$VITE_OPSLOG_API_URL
ENV VITE_AUTH_MODE=$VITE_AUTH_MODE
ENV VITE_OPSLOG_TOKEN=$VITE_OPSLOG_TOKEN
ENV VITE_OIDC_AUTHORITY=$VITE_OIDC_AUTHORITY
ENV VITE_OIDC_CLIENT_ID=$VITE_OIDC_CLIENT_ID
ENV VITE_OIDC_REDIRECT_URI=$VITE_OIDC_REDIRECT_URI
ENV VITE_OIDC_POST_LOGOUT_REDIRECT_URI=$VITE_OIDC_POST_LOGOUT_REDIRECT_URI
ENV VITE_OIDC_SCOPE=$VITE_OIDC_SCOPE
ENV VITE_OIDC_SILENT_REDIRECT_URI=$VITE_OIDC_SILENT_REDIRECT_URI

COPY dashboard/package*.json ./
RUN npm ci

COPY dashboard/ .
RUN npm run build

FROM caddy:2-alpine

COPY --from=builder /app/dist /var/www/html
COPY dashboard/Caddyfile /etc/caddy/Caddyfile

EXPOSE 8601

CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile"]
