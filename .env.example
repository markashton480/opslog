# =============================================================================
# Lintel OpsLog — Environment Configuration
# =============================================================================
# Copy to .env and fill in values before deploying.
# Required values are marked with (REQUIRED).

# --- Database -----------------------------------------------------------------
POSTGRES_USER=opslog
POSTGRES_PASSWORD=           # (REQUIRED) Strong password for the opslog DB user
POSTGRES_DB=opslog

# --- API Server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8600
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR

# --- Dashboard ----------------------------------------------------------------
VITE_OPSLOG_API_URL=/api/v1  # Relative path when using same-domain proxy
VITE_OPSLOG_TOKEN=           # Optional: pre-configured auth token for dashboard

# --- Networking ---------------------------------------------------------------
LISTEN_ADDR=127.0.0.1        # Bind address for exposed ports (127.0.0.1 = local only)
DASHBOARD_PORT=8601           # Host port for the dashboard/proxy service
