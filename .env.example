# =============================================================================
# Lintel OpsLog — Environment Configuration
# =============================================================================
# Copy to .env and fill in values before deploying.
# Required values are marked with (REQUIRED).

# --- Database -----------------------------------------------------------------
POSTGRES_USER=opslog
# (REQUIRED) Strong password for the opslog DB user
POSTGRES_PASSWORD=
POSTGRES_DB=opslog

# --- API Server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8600
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_USERNAME_CLAIM=preferred_username
OIDC_JWKS_URL=
OIDC_JWKS_TTL_SECONDS=3600
OIDC_HTTP_TIMEOUT_SECONDS=5.0

# --- Dashboard ----------------------------------------------------------------
# Relative path when using same-domain proxy
VITE_OPSLOG_API_URL=/api/v1
# token (legacy static token mode) or oidc (Keycloak login)
VITE_AUTH_MODE=oidc
# Optional: pre-configured auth token for dashboard token mode
VITE_OPSLOG_TOKEN=
VITE_OIDC_AUTHORITY=https://auth.lintel.digital/realms/lintel
VITE_OIDC_CLIENT_ID=opslog
VITE_OIDC_REDIRECT_URI=https://opslog.lintel.digital/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://opslog.lintel.digital/
VITE_OIDC_SCOPE=openid profile email
VITE_OIDC_SILENT_REDIRECT_URI=
OPSLOG_CSP_CONNECT_EXTRA=https://auth.lintel.digital
OPSLOG_CSP_FRAME_EXTRA=https://auth.lintel.digital

# --- Networking ---------------------------------------------------------------
# Bind address for exposed ports (127.0.0.1 = local only)
LISTEN_ADDR=127.0.0.1
# Host port for the dashboard/proxy service
DASHBOARD_PORT=8601
